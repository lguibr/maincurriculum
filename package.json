{
  "name": "maincurriculum-workspace",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev:backend": "npm run dev --workspace=@maincurriculum/backend",
    "dev:frontend": "npm run dev --workspace=@maincurriculum/frontend",
    "dev": "npx concurrently -c \"cyan,magenta\" -n \"backend,frontend\" \"npm run dev -w @maincurriculum/backend\" \"npm run dev -w @maincurriculum/frontend\"",
    "reset": "npm run db:reset --workspace=@maincurriculum/backend",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present"
  },
  "dependencies": {
    "@langchain/anthropic": "^1.3.26",
    "@langchain/openai": "^1.4.4"
  }
}
